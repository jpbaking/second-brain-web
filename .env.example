# Copy to `.env` (gitignored). compose-helper.sh passes this file to
# docker compose for variable substitution in docker-compose.yaml.
# Settings for compose-helper itself live in compose-helper.env instead.

# Encrypts provider API keys at rest (AES-256-GCM). Run ./configure (or
# configure.ps1) to generate this value and providers.yaml together.
SECOND_BRAIN_WEB_SECRETS_KEY=

# Where the container port is published on the host. The default keeps the app
# private to this machine; set BIND to a LAN IP or 0.0.0.0 so a TLS-terminating
# proxy elsewhere (e.g. nginx-proxy-manager) can front it.
#SECOND_BRAIN_WEB_BIND=127.0.0.1
#SECOND_BRAIN_WEB_PORT=8722

# DANGER: development disables the Secure flag on auth cookies. Only for
# plain-http LAN experiments without a TLS proxy; never on anything reachable
# from an untrusted network.
#SECOND_BRAIN_WEB_NODE_ENV=development

# Root/default log4js level. Accepted values: trace, debug, info, warn, error,
# fatal, off. Logs are emitted as one JSON object per line.
#SECOND_BRAIN_WEB_LOG_LEVEL=info
