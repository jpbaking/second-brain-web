#!/usr/bin/env bash
set -euo pipefail

# configure — launcher for the interactive Node configurator
# (app/server/src/cli/configure.ts). All logic lives in the app; this shim
# just finds a way to run it: the built app with host Node, else the Docker
# image. Linux/macOS only.

ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
CONFIG_DIR="$ROOT/.config"
mkdir -p "$CONFIG_DIR"
chmod 700 "$CONFIG_DIR" 2>/dev/null || true

# One-time migration: seed .config/.env from a legacy repo-root .env so existing
# secrets/settings survive. compose-helper prefers a root .env, so warn to drop it.
if [[ ! -f "$CONFIG_DIR/.env" && -f "$ROOT/.env" ]]; then
  cp "$ROOT/.env" "$CONFIG_DIR/.env"
  chmod 600 "$CONFIG_DIR/.env" 2>/dev/null || true
  printf 'configure: migrated %s → %s. Remove the repo-root .env (compose-helper prefers it).\n' \
    "$ROOT/.env" "$CONFIG_DIR/.env" >&2
fi

DIST="$ROOT/app/server/dist/cli/configure.js"
if command -v node >/dev/null 2>&1 && [[ -f "$DIST" ]]; then
  SBW_CONFIG_DIR="$CONFIG_DIR" exec node "$DIST"
fi

if command -v docker >/dev/null 2>&1 && docker image inspect second-brain-web >/dev/null 2>&1; then
  # -u maps host ownership onto the files written into the mount; ssh-keygen is
  # skipped gracefully if the slim image lacks it (run with host Node to generate).
  exec docker run --rm -it -u "$(id -u):$(id -g)" \
    -v "$CONFIG_DIR:/config" -e SBW_CONFIG_DIR=/config \
    second-brain-web node server/dist/cli/configure.js
fi

printf 'configure: need Node with the built app (cd app && npm run build) or the second-brain-web Docker image.\n' >&2
exit 1
